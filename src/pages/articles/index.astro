---
import Base from '../../layouts/Base.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import Search from '../../components/Search.astro';
import { collectTags, getPublishedArticles, withBase } from '../../utils/articles';

const articles = await getPublishedArticles();
const tags = collectTags(articles);
---

<Base
  title="All articles · Cyber Shield"
  description="Every Cyber Shield article on staying safe online — phishing, passwords, scams, privacy and more — newest first."
>
  <h1>All articles</h1>
  <p class="intro meta">
    {articles.length} plain-language guides to staying safe online, newest first.
  </p>

  <Search />

  <nav class="tag-filter" aria-label="Filter by tag">
    <span class="flank">Filter by topic</span>
    <ul class="chips">
      <li style="display:contents">
        <a class="chip" href={withBase('/articles/')} aria-current="true">all</a>
      </li>
      {
        tags.map((tag) => (
          <li style="display:contents">
            <a class="chip" href={withBase(`/tags/${tag}/`)}>
              {tag}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>

  <ul class="card-grid">
    {articles.map((article) => <ArticleCard article={article} headingLevel="h2" />)}
  </ul>
</Base>

<style>
  .intro {
    margin-top: 0.5rem;
  }

  .tag-filter {
    margin-block: 1.5rem 2rem;
  }

  .tag-filter .flank {
    margin-bottom: 0.75rem;
  }

  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
</style>
