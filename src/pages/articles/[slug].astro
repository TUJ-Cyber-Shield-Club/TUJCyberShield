---
import { render } from 'astro:content';
import { Image, getImage } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import {
  formatDate,
  getPublishedArticles,
  issueLabel,
  readingTime,
  withBase,
  type Article,
} from '../../utils/articles';

export async function getStaticPaths() {
  const articles = await getPublishedArticles();
  return articles.map((article, index) => ({
    params: { slug: article.id },
    props: {
      article,
      // articles are sorted newest first
      newer: articles[index - 1] ?? null,
      older: articles[index + 1] ?? null,
      sameIssue: articles.filter(
        (other) => other.data.issue === article.data.issue && other.id !== article.id
      ),
    },
  }));
}

interface Props {
  article: Article;
  newer: Article | null;
  older: Article | null;
  sameIssue: Article[];
}

const { article, newer, older, sameIssue } = Astro.props;
const { title, description, pubDate, authors, tags, issue, coverImage, coverAlt } = article.data;
const { Content } = await render(article);
const minutes = readingTime(article.body);

const ogImage = coverImage
  ? new URL((await getImage({ src: coverImage, width: 1200 })).src, Astro.site).href
  : undefined;
---

<Base title={`${title} · Cyber Shield`} description={description} ogType="article" ogImage={ogImage}>
  <article data-pagefind-body>
    <header class="article-head">
      <p class="flank">
        <a href={withBase(`/issues/${issue}/`)} data-pagefind-ignore>{issueLabel(issue)} issue</a>
      </p>
      <h1>{title}</h1>
      <p class="lede">{description}</p>
      <p class="meta byline">
        <b>{authors.join(', ')}</b> ·{' '}
        <time datetime={pubDate.toISOString().slice(0, 10)}>{formatDate(pubDate)}</time> ·
        {` ${minutes} min read`}
      </p>
      {
        tags.length > 0 && (
          <ul class="chips" aria-label="Tags" data-pagefind-ignore>
            {tags.map((tag) => (
              <li style="display:contents">
                <a class="chip" href={withBase(`/tags/${tag}/`)} data-pagefind-filter="topic">
                  {tag}
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </header>

    {
      coverImage && coverAlt && (
        <Image class="cover" src={coverImage} alt={coverAlt} width="1400" loading="eager" />
      )
    }

    <div class="prose">
      <Content />
    </div>
  </article>

  {
    sameIssue.length > 0 && (
      <aside class="section related" aria-labelledby="related-heading">
        <h2 class="flank flank--lead" id="related-heading">
          More from the {issueLabel(issue)} issue
        </h2>
        <ul>
          {sameIssue.map((other) => (
            <li>
              <a href={withBase(`/articles/${other.id}/`)}>{other.data.title}</a>
              <span class="meta"> — {other.data.description}</span>
            </li>
          ))}
        </ul>
      </aside>
    )
  }

  <nav class="section pager" aria-label="Article navigation">
    {
      older ? (
        <a class="pager-link" href={withBase(`/articles/${older.id}/`)} rel="prev">
          <span class="meta">← Older</span>
          <span>{older.data.title}</span>
        </a>
      ) : (
        <span />
      )
    }
    {
      newer ? (
        <a class="pager-link pager-next" href={withBase(`/articles/${newer.id}/`)} rel="next">
          <span class="meta">Newer →</span>
          <span>{newer.data.title}</span>
        </a>
      ) : (
        <span />
      )
    }
  </nav>
</Base>

<style>
  article {
    max-width: 46rem;
    margin-inline: auto;
  }

  .article-head h1 {
    font-size: clamp(1.9rem, 5vw, 2.7rem);
    margin-top: 0.9rem;
  }

  .flank a {
    color: inherit;
    text-decoration: none;
  }

  .flank a:hover {
    text-decoration: underline;
  }

  .lede {
    margin-top: 0.9rem;
    font-family: var(--font-body);
    font-size: 1.15rem;
    line-height: 1.6;
    color: var(--text-muted);
  }

  .byline {
    margin-top: 0.9rem;
  }

  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    list-style: none;
    margin: 1rem 0 0;
    padding: 0;
  }

  .cover {
    margin-top: 1.75rem;
    border-radius: 10px;
    border: 1px solid var(--line);
  }

  .prose {
    margin-top: 2.25rem;
  }

  .related,
  .pager {
    max-width: 46rem;
    margin-inline: auto;
    margin-top: clamp(2.5rem, 7vw, 4rem);
  }

  .related ul {
    list-style: none;
    margin: 1.25rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .related a {
    font-weight: 650;
  }

  .pager {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    border-top: 1px solid var(--line);
    padding-top: 1.5rem;
  }

  .pager-link {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    text-decoration: none;
    font-weight: 650;
  }

  .pager-link:hover span:last-child {
    text-decoration: underline;
  }

  .pager-next {
    text-align: right;
    align-items: flex-end;
  }

  @media (max-width: 34rem) {
    .pager {
      grid-template-columns: 1fr;
    }

    .pager-next {
      text-align: left;
      align-items: flex-start;
    }
  }
</style>
