---
import Base from '../layouts/Base.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getPublishedArticles, issueLabel, withBase } from '../utils/articles';

const articles = await getPublishedArticles();
const latestIssue = articles[0]?.data.issue;
const latestIssueArticles = articles.filter((a) => a.data.issue === latestIssue);
const earlier = articles.filter((a) => a.data.issue !== latestIssue).slice(0, 6);
---

<Base
  title="Cyber Shield — digital safety, in plain language"
  description="Monthly, plain-language security advice from TUJ's Cyber Shield Club: phishing, passwords, scams, and privacy explained for everyday students."
>
  <section class="hero">
    <p class="flank flank--center">A TUJ student publication</p>
    <h1>Digital safety, in plain language.</h1>
    <p class="lede">
      Every month, Cyber Shield students research the scams, leaks, and tricks aimed at people like
      us — then explain exactly what to do about them. No jargon, no fear, no tech degree required.
    </p>
    <div class="cta">
      {latestIssue && <a class="button" href={withBase(`/issues/${latestIssue}/`)}>Read the latest issue</a>}
      <a class="button button--ghost" href={withBase('/about/')}>About the club</a>
    </div>
  </section>

  {
    latestIssue && (
      <section class="section" aria-labelledby="latest-heading">
        <h2 class="flank flank--lead" id="latest-heading">
          The {issueLabel(latestIssue)} issue
        </h2>
        <ul class="card-grid">
          {latestIssueArticles.map((article, i) => (
            <ArticleCard article={article} eager={i === 0} />
          ))}
        </ul>
        <p class="more">
          <a href={withBase(`/issues/${latestIssue}/`)}>Everything in this issue →</a>
        </p>
      </section>
    )
  }

  {
    earlier.length > 0 && (
      <section class="section" aria-labelledby="recent-heading">
        <h2 class="flank flank--lead" id="recent-heading">
          Recently published
        </h2>
        <ul class="card-grid">
          {earlier.map((article) => (
            <ArticleCard article={article} />
          ))}
        </ul>
      </section>
    )
  }

  <section class="section">
    <p class="more">
      <a href={withBase('/articles/')}>Browse all articles</a> ·{' '}
      <a href={withBase('/issues/')}>Issue archive</a>
    </p>
  </section>
</Base>

<style>
  .hero {
    text-align: center;
    max-width: 46rem;
    margin-inline: auto;
    padding-block: clamp(1rem, 5vw, 3rem);
  }

  .hero h1 {
    font-size: clamp(2.1rem, 6vw, 3.4rem);
    margin-top: 1.1rem;
  }

  .lede {
    margin-top: 1.2rem;
    font-family: var(--font-body);
    font-size: 1.15rem;
    line-height: 1.65;
    color: var(--text-muted);
  }

  .cta {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 1.75rem;
  }

  .flank--lead {
    margin-bottom: 1.5rem;
  }

  .more {
    margin-top: 1.4rem;
    font-weight: 600;
  }
</style>
