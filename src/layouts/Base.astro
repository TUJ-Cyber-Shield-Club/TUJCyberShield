---
import '@fontsource-variable/bricolage-grotesque';
import '@fontsource-variable/source-serif-4';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { withBase } from '../utils/articles';

interface Props {
  title: string;
  description: string;
  /** Absolute URL for the social-preview image. Defaults to the club logo card. */
  ogImage?: string;
  ogType?: 'website' | 'article';
}

const { title, description, ogImage, ogType = 'website' } = Astro.props;

const site = Astro.site!;
const canonical = new URL(Astro.url.pathname, site);
const socialImage = ogImage ?? new URL(withBase('/og-default.png'), site).href;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="generator" content={Astro.generator} />

    <link rel="icon" href={withBase('/favicon.ico')} sizes="32x32" />
    <link rel="icon" href={withBase('/icon-192.png')} type="image/png" sizes="192x192" />
    <link rel="apple-touch-icon" href={withBase('/apple-touch-icon.png')} />

    <link
      rel="alternate"
      type="application/rss+xml"
      title="Cyber Shield articles"
      href={withBase('/rss.xml')}
    />
    <link rel="sitemap" href={withBase('/sitemap-index.xml')} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:site_name" content="Cyber Shield" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />

    <!-- Apply a saved theme before first paint so there is no flash. -->
    <script is:inline>
      (() => {
        try {
          const theme = localStorage.getItem('theme');
          if (theme === 'light' || theme === 'dark') {
            document.documentElement.dataset.theme = theme;
          }
        } catch {
          /* storage unavailable: fall back to prefers-color-scheme */
        }
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Header />
    <main id="main" class="wrap">
      <slot />
    </main>
    <Footer />
  </body>
</html>
